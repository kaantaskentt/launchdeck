{
  "name": "launchdeck",
  "private": false,
  "version": "0.1.0",
  "description": "A local-first open-source project cockpit for importing projects, inspecting health, editing files, and previewing safely.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "developer-tools",
    "open-source",
    "project-dashboard",
    "github",
    "vite",
    "react",
    "local-first"
  ],
  "homepage": "https://github.com/kaantaskentt/launchdeck#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaantaskentt/launchdeck.git"
  },
  "bugs": {
    "url": "https://github.com/kaantaskentt/launchdeck/issues"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
